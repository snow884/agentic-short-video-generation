

from vocode.streaming.models.synthesizer import CoquiTTSSynthesizerConfig
from vocode.streaming.synthesizer.coqui_tts_synthesizer import CoquiTTSSynthesizer
from vocode.streaming.models.audio_encoding import AudioEncoding
import sounddevice as sd

# Configure output device
speaker_output = sd.OutputStream(samplerate=48000, channels=1)
speaker_output.start()

# Configure Coqui TTS Synthesizer
synthesizer = CoquiTTSSynthesizer(
    CoquiTTSSynthesizerConfig.from_output_device(
        speaker_output,
        tts_kwargs={"model_name": "tts_models/en/ljspeech/tacotron2-DDC_ph"},
        audio_encoding=AudioEncoding.PCM_S16LE
    )
)

# Synthesize text
text = "Hello, this is a test of Vocode's text-to-speech functionality."
chunk_generator = synthesizer.synthesize(text)

# Play the synthesized audio
for chunk in chunk_generator:
    speaker_output.write(chunk.audio)

speaker_output.stop()
speaker_output.close()